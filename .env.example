############
# Secrets — generate via setup.sh
############

# Main DB password. All Supabase service roles share this (supabase_admin,
# authenticator, supabase_auth_admin, etc.).
# openssl rand -base64 32
POSTGRES_PASSWORD=your-super-secret-db-password

# Shared JWT signing secret (PostgREST, GoTrue).
# openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# JWT expiry in seconds (default 1 hour).
JWT_EXP=3600

# Admin panel access token.
# openssl rand -base64 48
ADMIN_TOKEN=your-admin-token

# HMAC key for signed auth cookies (used for /studio/* cookie gate).
# openssl rand -base64 32
COOKIE_SIGNING_KEY=your-cookie-signing-key

# Encrypt key for Studio's stored connection metadata (postgres-meta).
# openssl rand -base64 32
PG_META_CRYPTO_KEY=your-pg-meta-crypto-key

############
# API Keys — generated by setup.sh (JWTs signed with JWT_SECRET)
############

ANON_KEY=eyJ...your-anon-key
SERVICE_ROLE_KEY=eyJ...your-service-role-key

############
# Networking
############

# Public URL that end-users hit (Caddy listens here).
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000

# CORS — one regex alternation of allowed frontend origins.
# Empty = fall back to SITE_URL literal. For multiple frontends
# (web + mobile + marketing + admin), escape dots and join with `|`:
#   CORS_ALLOWED_ORIGINS_REGEX=https://app\.com|https://admin\.app\.com
CORS_ALLOWED_ORIGINS_REGEX=

# GoTrue allowed redirect URIs (beyond SITE_URL). Comma-separated.
# Required when frontends call `signInWithOAuth({ redirectTo: ... })`
# with URLs not matching SITE_URL (e.g. mobile deep links:
# `myapp://auth,https://marketing.app.com/welcome`).
GOTRUE_URI_ALLOW_LIST=

# PostgreSQL port binding. Default: loopback only.
# Set to 0.0.0.0 to expose externally (only if you know what you're doing).
POSTGRES_BIND_ADDR=127.0.0.1

############
# HTTPS / TLS (Phase 7.3 — auto_https via Let's Encrypt)
############
# Default is http-only on :8000. To enable HTTPS:
#   1. Point a public DNS A/AAAA record at this host.
#   2. Set CADDY_SITE_ADDR below to that domain (e.g. db.example.com).
#      Multiple domains: space-separate, e.g. "a.example.com b.example.com".
#   3. Update API_EXTERNAL_URL above to https://<domain>.
#   4. Make sure ports 80 + 443 are reachable from the public internet
#      (HTTP-01 challenge uses :80; serving uses :443).
#   5. Start the stack WITH the HTTPS override file:
#        docker compose -f docker-compose.yml -f docker-compose.https.yml up -d
#      Caddy auto-issues and renews the cert. Certs persist in the
#      caddy-data named volume (not wiped by `docker compose down`).
#
# The override file exists as a separate opt-in so a default
# `docker compose up` never tries to bind host :80 or :443 (which would
# break upgrades for hosts that already have something on those ports).
# For a custom cert (internal CA, wildcard), edit the Caddyfile directly.
CADDY_SITE_ADDR=:8000

# Host IP binding for gateway ports.
# GATEWAY_HTTP_BIND — for the :8000 listener (admin-api).
#   Default empty = 0.0.0.0 (all interfaces). Set to 127.0.0.1 for local-only.
# CADDY_HTTPS_BIND — only consulted when using docker-compose.https.yml.
#   Default empty = 0.0.0.0 (what Let's Encrypt needs). Set to 127.0.0.1
#   if you terminate TLS at an upstream load balancer.
GATEWAY_HTTP_BIND=
CADDY_HTTPS_BIND=

# Host path of this project. Used by admin container to run `docker compose`
# against the host daemon. setup.sh auto-fills this.
HOST_PROJECT_DIR=

############
# GoTrue / Auth
############

# Set to true for invite-only mode.
GOTRUE_DISABLE_SIGNUP=false

# Anonymous sign-in (GoTrue 2.170+).
GOTRUE_EXTERNAL_ANONYMOUS_USERS_ENABLED=true

# Email (SMTP) — required for email/password signup with confirmation.
# Leave empty + GOTRUE_MAILER_AUTOCONFIRM=true to skip email verification.
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=noreply@example.com
GOTRUE_MAILER_AUTOCONFIRM=true

# OAuth — GitHub
GOTRUE_EXTERNAL_GITHUB_ENABLED=false
GOTRUE_EXTERNAL_GITHUB_CLIENT_ID=
GOTRUE_EXTERNAL_GITHUB_SECRET=
GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI=http://localhost:8000/auth/v1/callback

# OAuth — Google
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/v1/callback

# OAuth — Apple
GOTRUE_EXTERNAL_APPLE_ENABLED=false
GOTRUE_EXTERNAL_APPLE_CLIENT_ID=
GOTRUE_EXTERNAL_APPLE_SECRET=
GOTRUE_EXTERNAL_APPLE_REDIRECT_URI=http://localhost:8000/auth/v1/callback

############
# Container images
############
# By default `docker compose up` pulls admin + db images from GHCR.
# If the pull fails (offline, rate-limited, forked to a private
# registry), compose automatically falls back to building from
# source. Override these to point at your own registry when forking.
#
# ADMIN_IMAGE=ghcr.io/myorg/supalite-admin:latest
# DB_IMAGE=ghcr.io/myorg/supalite-db:latest

############
# Admin
############

# Marked true by the setup wizard on first run.
SETUP_COMPLETE=false

############
# Backup — logical (pg_dump) to S3-compatible object storage
############
# Supports AWS S3, Cloudflare R2, MinIO, Ceph, Backblaze B2, etc.
# Leave BACKUP_S3_ENDPOINT empty for AWS; set to https://<host> for others.
# BACKUP_S3_PATH_STYLE=true is required for MinIO/Ceph.

BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_PATH_STYLE=false
BACKUP_S3_PREFIX=backup/

# Scheduled pg_dump backups + retention (admin-process internal cron).
# Off by default. Set BACKUP_SCHEDULE_HOURS=24 for daily backups.
# When BACKUP_RETENTION_COUNT is also set, the N newest scheduled
# backups are kept; older `scheduled-*.dump` objects are deleted
# automatically after each successful run. Manual backups
# (`pgdump-*.dump`) are NEVER touched by retention.
BACKUP_SCHEDULE_HOURS=
BACKUP_RETENTION_COUNT=

# pgBackRest path inside the bucket (separate from pg_dump prefix to
# avoid collisions). Only consulted when PGBACKREST_ARCHIVE_MODE=on.
BACKUP_S3_PGBACKREST_PATH=/pgbackrest

############
# pgBackRest — physical incremental backups (Phase 6.2, opt-in)
############
# OFF by default. Enabling requires a Postgres restart (archive_mode
# is a postmaster-level GUC). Switch archive_mode=on + archive_command
# to the pgbackrest push invocation, then `docker compose restart db`,
# then run "Initialize" in the admin panel to create the stanza.

PGBACKREST_ARCHIVE_MODE=off
# Default points at pgbackrest so that enabling archive_mode without
# initializing a stanza fails LOUDLY (Postgres logs archive errors)
# rather than silently succeeding and losing WAL. When archive_mode=off
# this is never invoked.
PGBACKREST_ARCHIVE_COMMAND=pgbackrest --stanza=main archive-push %p
PGBACKREST_WAL_LEVEL=replica
PGBACKREST_MAX_WAL_SENDERS=3

############
# Docker Compose profiles (optional services)
############
# studio      — enable Supabase Studio (default)
# pgbackrest  — scaffolding present (Phase 6.2a); backup execution + restore pending
# Delete this line for the minimal stack (no Studio, no postgres-meta).
COMPOSE_PROFILES=studio
