# Secrets generated by setup.sh
.env
.env.*
!.env.example

# Local data, never commit
*.db
*.sqlite
*.sqlite3
volumes/db/data/

# Build artifacts
admin/admin-server
admin/web/.next/
admin/web/out/
admin/web/node_modules/
admin/web/*.tsbuildinfo
docs-site/node_modules/
docs-site/dist/
docs-site/.astro/

# Caddy data persists in named volume; never appears as a file in repo,
# but if someone bind-mounts it into ./caddy-data we don't want to commit
# certs/account keys.
caddy-data/
caddy-config/

# Editor / OS junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Go test/cover output
*.out
*.test
*.prof

# Example project local state
examples/*/.env
examples/*/.env.local
examples/*/.next/
examples/*/node_modules/
# But explicitly keep the env templates that ship in git.
!examples/*/.env.example
!examples/*/.env.local.example
