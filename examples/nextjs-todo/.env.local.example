# Where SupaLite's gateway lives. The default `setup.sh` config exposes
# it on :8000 of the host running the docker compose stack.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# Anon key — visible to clients. Find it on SupaLite's admin dashboard
# (or in `.env` of the SupaLite repo as ANON_KEY).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
